#!/bin/zsh

# ==============
# Git Worktree
# ===============

_fzf_git_worktree_sel() {
    git worktree list | fzf \
        --prompt="$1" \
        --height 40% \
        --reverse |
        awk '{print $1}'
}

# Usage: gwc feature/branch-name
gwc() # Create Git worktree and switch to it
{
  local branch=$1
  local dir=${2:-$branch}

  [[ -z $branch ]] && { echo "usage: gwc <branch-name> [directory-name]" >&2; return 1; }

  # figure out the default branch (works even if it is not checked out locally)
  local default
  default=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
  # fallback for very old clones that lack the symbolic-ref
  [[ -z $default ]] && default=$(git branch -rl '*/master' '*/main' | tail -1 | sed 's@.*/@@')

  git worktree add -b "$branch" ../"$dir" "$default" \
    && cd ../"$dir" \
    && p install
}

worktree() # Switch Git worktree with FZF
{
    local target
    target=$(_fzf_git_worktree_sel "Switch Worktree: ")

    if [[ -n "$target" ]]; then
        cd "$target" || return
    fi
}

gwrm() {
    local target
    target=$(_fzf_git_worktree_sel "Delete Worktree: ")

    if [[ -n "$target" ]]; then
        # -i provides a confirmation prompt from git itself
        git worktree remove "$target"
    fi
}
